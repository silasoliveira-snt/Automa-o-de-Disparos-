# Supabase (banco de dados)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=sua_service_role_key

# OpenAI (agente e análises GPT)
OPENAI_API_KEY=sk-...

# Agile Talk / Onochat (envio de WhatsApp)
AGILE_BEARERTOKEN=
AGILE_CLIENT_PATH=

# Número do gestor autorizado a falar com o agente (formato: 5511920202020)
GESTOR_NUMBER=

# Outros números autorizados, separados por vírgula (opcional)
AGENTE_NUMEROS_AUTORIZADOS=

# ID do grupo de WhatsApp dos franqueados (formato: 120363xxxxx@g.us)
GRUPO_FRANQUEADOS=

# Link do formulário comportamental (Tally, encurtado de preferência)
LINK_COMPORTAMENTAL=
